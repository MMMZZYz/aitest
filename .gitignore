# Git 忽略规则：环境变量、Python 缓存、IDE、系统文件等
# 环境变量和密钥（包含 API Key，切勿提交）
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 以下目录只保留空文件夹结构（.gitkeep），不提交内部文件
inputs/*
!inputs/.gitkeep
outputs/*
!outputs/.gitkeep
xmind_excel_input/*
!xmind_excel_input/.gitkeep
xmind_excel_output/*
!xmind_excel_output/.gitkeep
