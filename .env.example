# 配置模板：复制为 .env 后填写
# 二选一：使用 Gemini 或 DashScope（通义千问）

# ---------- Gemini（Google AI Studio）----------
# 在 https://aistudio.google.com/apikey 申请 API Key，填下面即可使用 Gemini
GEMINI_API_KEY=

# 可选：模型名（如 gemini-1.5-flash、gemini-2.0-flash）；请求超时（秒），默认 180，避免卡住
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_VISION_MODEL=gemini-1.5-flash
# GEMINI_TIMEOUT_SEC=180

# ---------- 阿里云 DashScope（通义千问）----------
# 若不使用 Gemini，则必填 DashScope API Key
DASHSCOPE_API_KEY=

# 可选：文本模型，默认 qwen-plus
# DASHSCOPE_MODEL=qwen-plus

# 可选：视觉模型（需求截图识别等），默认 qwen-vl-plus
# DASHSCOPE_VISION_MODEL=qwen-vl-plus
